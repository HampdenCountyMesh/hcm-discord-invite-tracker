# Required Discord settings
DISCORD_TOKEN=replace-with-bot-token
GUILD_ID=replace-with-hcm-server-id

# Recommended HCM channel settings
# A private staff/project log channel receives join-attribution messages.
LOG_CHANNEL_ID=replace-with-private-log-channel-id
# New permanent invites created by /source provision-all point here.
DEFAULT_INVITE_CHANNEL_ID=replace-with-welcome-or-lobby-channel-id

# Optional: comma-separated Discord role IDs allowed to use tracker commands.
# Members with Manage Server or Administrator are already allowed.
ADMIN_ROLE_IDS=

# HCM deployment paths on Meshcore-Hub
DATABASE_PATH=/data/invite-tracker.sqlite3
SOURCE_CONFIG_PATH=/app/config/hcm-sources.yml
WEBSITE_EXPORT_PATH=/data/discord-invites.yml
BACKUP_DIR=/data/backups
BACKUP_KEEP=14

# Personal member identifiers are removed from old join rows after this many days.
# Source totals remain. Set 0 to disable automatic identity purging.
IDENTITY_RETENTION_DAYS=90
TIMEZONE=America/New_York

# Dashboard is bound to localhost by compose.hcm.yml.
DASHBOARD_ENABLED=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8091
# Optional application-level Basic authentication. Recommended before any proxy exposure.
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=

INVITE_REFRESH_SECONDS=600
LOG_LEVEL=INFO
